CompileFlags:
  Add: [
    "-Iinclude",
    "-Igenerated",
    "-DEMSCRIPTEN",
    # Paths reais da sua instalação do Emscripten 5.0.5
    "-isystem", "/opt/homebrew/Cellar/emscripten/5.0.5/libexec/cache/sysroot/include",
    "-isystem", "/opt/homebrew/Cellar/emscripten/5.0.5/libexec/cache/sysroot/include/compat",
    "-isystem", "/opt/homebrew/Cellar/emscripten/5.0.5/libexec/cache/sysroot/include/fakesdl",
    "-isystem", "/opt/homebrew/Cellar/emscripten/5.0.5/libexec/llvm/lib/clang/23/include",
    # Target correto para não confundir o LSP com headers do host (macOS)
    "--target=wasm32-unknown-emscripten"
  ]
  Remove: [
    "-mllvm",
    "-fignore-exceptions",
    "-mrelax-all",
    "--sysroot=*"
  ]
