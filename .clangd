CompileFlags:
  Add:
    - "-target"
    - "wasm32-unknown-emscripten"
    - "-DEMSCRIPTEN"
    - "-Isrc"
    - "-isysroot"
    - "/opt/homebrew/Cellar/emscripten/5.0.3/libexec/cache/sysroot"
    - "-isystem"
    - "/opt/homebrew/Cellar/emscripten/5.0.3/libexec/cache/sysroot/include"
    - "-isystem"
    - "/opt/homebrew/Cellar/emscripten/5.0.3/libexec/llvm/lib/clang/23/include"
  Remove:
    - "-MJ*"
    - "-flto"
    - "-Oz"
